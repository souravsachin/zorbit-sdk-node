{
  "name": "@zorbit-platform/sdk-node",
  "version": "0.1.0",
  "description": "Node.js/TypeScript SDK for building applications on the Zorbit platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "zorbit",
    "platform",
    "sdk",
    "middleware",
    "mach"
  ],
  "author": "Zorbit Platform",
  "license": "UNLICENSED",
  "dependencies": {
    "jsonwebtoken": "^9.0.2",
    "kafkajs": "^2.2.4",
    "@opentelemetry/api": "^1.7.0",
    "@opentelemetry/sdk-node": "^0.48.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.48.0",
    "axios": "^1.6.7",
    "mongoose": "^8.0.0",
    "uuid": "^9.0.0"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/config": "^3.0.0 || ^4.0.0",
    "@nestjs/passport": "^10.0.0 || ^11.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs/common": { "optional": true },
    "@nestjs/config": { "optional": true },
    "@nestjs/passport": { "optional": true },
    "passport": { "optional": true },
    "passport-jwt": { "optional": true }
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "@types/node": "^20.11.16",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/jest": "^29.5.12",
    "@types/express": "^4.17.21",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/core": "^10.3.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "@types/passport-jwt": "^4.0.1",
    "@types/uuid": "^9.0.0",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/tests"],
    "testMatch": ["**/*.spec.ts"],
    "modulePathIgnorePatterns": ["<rootDir>/dist"]
  }
