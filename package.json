{
  "name": "@zorbit-platform/sdk-node",
  "version": "0.1.0",
  "description": "Node.js/TypeScript SDK for building applications on the Zorbit platform",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "zorbit",
    "platform",
    "sdk",
    "middleware",
    "mach"
  ],
  "author": "Zorbit Platform",
  "license": "UNLICENSED",
  "dependencies": {
    "jsonwebtoken": "^9.0.2",
    "kafkajs": "^2.2.4",
    "@opentelemetry/api": "^1.7.0",
    "@opentelemetry/sdk-node": "^0.48.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.48.0",
    "axios": "^1.6.7"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "@types/node": "^20.11.16",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/jest": "^29.5.12",
    "@types/express": "^4.17.21"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/tests"],
    "testMatch": ["**/*.spec.ts"]
  }
}
